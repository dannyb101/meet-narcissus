{
  "manifest_version": 3,
  "name": "Meet Self-View Center",
  "version": "1.1.0",
  "description": "Overlay self-view for Google Meet.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://meet.google.com/*"],
  "action": {
    "default_title": "Toggle self-view overlay"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["hook.js"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}